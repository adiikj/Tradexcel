generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String    @id @default(cuid())
  name         String
  username     String    @unique
  avatar       String
  email        String    @unique
  password     String?
  googleId     String?   @unique
  otp          String?
  otpExpiry    DateTime?
  otpVerified  Boolean   @default(false)
  dob          DateTime?
  pin          String?
  refreshToken String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  // Daily-login streak - advanced only on explicit logins (see recordLogin),
  // not on silent token refreshes.
  currentStreak Int       @default(0)
  longestStreak Int       @default(0)
  lastLoginDate DateTime? @db.Date

  wallet                Wallet?
  holdings              Holding[]
  transactions          Transaction[]
  contestEntries        ContestEntry[]
  ownedContests         Contest[]        @relation("ContestOwner")
  priceAlerts           PriceAlert[]
  following             Follow[]         @relation("Following")
  followers             Follow[]         @relation("Followers")
  notificationsReceived Notification[]   @relation("NotificationRecipient")
  notificationsCaused   Notification[]   @relation("NotificationActor")
  weeklySnapshots       WeeklySnapshot[]
  badges                UserBadge[]
}

// Earned records only - badge definitions (name/description/icon) live in
// services/achievements.ts, looked up by badgeId, so adding/editing a badge
// never needs a migration.
model UserBadge {
  id       String   @id @default(cuid())
  userId   String
  user     User     @relation(fields: [userId], references: [id])
  badgeId  String
  earnedAt DateTime @default(now())

  @@unique([userId, badgeId])
  @@index([userId])
}

// One row per user per completed week - written by the weekly reset job
// right before it force-liquidates holdings and resets the wallet back to
// STARTING_BALANCE, so profiles can show a "how did last week go" history.
model WeeklySnapshot {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id])
  weekStart    DateTime
  weekEnd      DateTime
  startBalance Decimal  @db.Decimal(18, 2)
  endNetWorth  Decimal  @db.Decimal(18, 2)
  pnlPercent   Decimal  @db.Decimal(10, 4)
  createdAt    DateTime @default(now())

  @@unique([userId, weekStart])
  @@index([userId, weekStart])
}

enum NotificationType {
  FOLLOW
  ACHIEVEMENT
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  user      User             @relation("NotificationRecipient", fields: [userId], references: [id])
  actorId   String?
  actor     User?            @relation("NotificationActor", fields: [actorId], references: [id])
  type      NotificationType
  message   String
  link      String?
  read      Boolean          @default(false)
  createdAt DateTime         @default(now())

  @@index([userId, createdAt])
}

model Follow {
  id          String   @id @default(cuid())
  followerId  String
  follower    User     @relation("Following", fields: [followerId], references: [id])
  followingId String
  following   User     @relation("Followers", fields: [followingId], references: [id])
  createdAt   DateTime @default(now())

  @@unique([followerId, followingId])
  @@index([followingId])
}

enum Side {
  BUY
  SELL
}

model Wallet {
  id        String   @id @default(cuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id])
  balance   Decimal  @default(100000) @db.Decimal(18, 2)
  currency  String   @default("INR")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Holding {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  symbol      String
  quantity    Int
  avgBuyPrice Decimal  @db.Decimal(18, 4)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([userId, symbol])
}

model Transaction {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  symbol    String
  side      Side
  quantity  Int
  price     Decimal  @db.Decimal(18, 4)
  total     Decimal  @db.Decimal(18, 2)
  createdAt DateTime @default(now())
}

enum ContestStatus {
  UPCOMING
  LIVE
  ENDED
}

enum ContestVisibility {
  PUBLIC
  PRIVATE
}

// Each entry gets its own isolated virtual wallet + holdings, seeded from
// startingBalance at join and traded only within `symbols` - decoupled from
// the user's real Wallet/Holding so contests can't leak into (or be leaked
// into by) normal trading.
model Contest {
  id                  String            @id @default(cuid())
  name                String
  startAt             DateTime
  endAt               DateTime
  startingBalance     Decimal           @default(100000) @db.Decimal(18, 2)
  symbols             String[]
  status              ContestStatus     @default(UPCOMING)
  visibility          ContestVisibility @default(PUBLIC)
  prize               String?
  imageUrl            String?
  inviteCode          String?           @unique
  ownerId             String?
  owner               User?             @relation("ContestOwner", fields: [ownerId], references: [id])
  // Presence of historicalStartDate marks this contest as a "past event"
  // replay - historicalDates is the resolved, ordered list of historical
  // trading dates (one per real contest day) populated once at creation.
  // Null/empty means an ordinary contest trading at live prices, unchanged.
  historicalStartDate DateTime?         @db.Date
  historicalDates     DateTime[]        @db.Date
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt

  entries ContestEntry[]

  @@index([visibility, startAt])
  @@index([ownerId])
}

// A shared cache of historical daily closes, keyed by symbol+date rather
// than contest - so multiple replay contests reusing the same symbol/date
// range don't refetch or duplicate storage.
model ContestHistoricalPrice {
  id     String   @id @default(cuid())
  symbol String
  date   DateTime @db.Date
  close  Decimal  @db.Decimal(18, 4)

  @@unique([symbol, date])
}

model ContestEntry {
  id            String   @id @default(cuid())
  contestId     String
  contest       Contest  @relation(fields: [contestId], references: [id])
  userId        String
  user          User     @relation(fields: [userId], references: [id])
  joinedAt      DateTime @default(now())
  balance       Decimal  @db.Decimal(18, 2)
  finalRank     Int?
  finalNetWorth Decimal? @db.Decimal(18, 2)

  holdings     ContestHolding[]
  transactions ContestTransaction[]

  @@unique([contestId, userId])
}

model ContestHolding {
  id             String       @id @default(cuid())
  contestEntryId String
  contestEntry   ContestEntry @relation(fields: [contestEntryId], references: [id])
  symbol         String
  quantity       Int
  avgBuyPrice    Decimal      @db.Decimal(18, 4)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@unique([contestEntryId, symbol])
}

model ContestTransaction {
  id             String       @id @default(cuid())
  contestEntryId String
  contestEntry   ContestEntry @relation(fields: [contestEntryId], references: [id])
  symbol         String
  side           Side
  quantity       Int
  price          Decimal      @db.Decimal(18, 4)
  total          Decimal      @db.Decimal(18, 2)
  createdAt      DateTime     @default(now())
}

enum AlertDirection {
  ABOVE
  BELOW
}

model PriceAlert {
  id          String         @id @default(cuid())
  userId      String
  user        User           @relation(fields: [userId], references: [id])
  symbol      String
  targetPrice Decimal        @db.Decimal(18, 4)
  direction   AlertDirection
  triggered   Boolean        @default(false)
  triggeredAt DateTime?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
}
