generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String    @id @default(cuid())
  name         String
  username     String    @unique
  avatar       String
  email        String    @unique
  password     String?
  googleId     String?   @unique
  otp          String?
  otpExpiry    DateTime?
  otpVerified  Boolean   @default(false)
  dob          DateTime?
  pin          String?
  refreshToken String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  wallet         Wallet?
  holdings       Holding[]
  transactions   Transaction[]
  contestEntries ContestEntry[]
}

enum Side {
  BUY
  SELL
}

model Wallet {
  id        String   @id @default(cuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id])
  balance   Decimal  @default(100000) @db.Decimal(18, 2)
  currency  String   @default("INR")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Holding {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  symbol      String
  quantity    Int
  avgBuyPrice Decimal  @db.Decimal(18, 4)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([userId, symbol])
}

model Transaction {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  symbol    String
  side      Side
  quantity  Int
  price     Decimal  @db.Decimal(18, 4)
  total     Decimal  @db.Decimal(18, 2)
  createdAt DateTime @default(now())
}

enum ContestStatus {
  UPCOMING
  LIVE
  ENDED
}

// v1 contests rank participants by their existing main-portfolio net worth
// delta since they joined — not an isolated per-contest wallet. Simpler to
// build and reason about; isolated wallets are a documented stretch goal.
model Contest {
  id              String        @id @default(cuid())
  name            String
  startAt         DateTime
  endAt           DateTime
  startingBalance Decimal       @default(100000) @db.Decimal(18, 2)
  status          ContestStatus @default(UPCOMING)
  prize           String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  entries ContestEntry[]
}

model ContestEntry {
  id            String    @id @default(cuid())
  contestId     String
  contest       Contest   @relation(fields: [contestId], references: [id])
  userId        String
  user          User      @relation(fields: [userId], references: [id])
  joinedAt      DateTime  @default(now())
  joinNetWorth  Decimal   @db.Decimal(18, 2)
  finalRank     Int?
  finalNetWorth Decimal?  @db.Decimal(18, 2)

  @@unique([contestId, userId])
}
